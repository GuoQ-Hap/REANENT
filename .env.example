# 复制本文件为 .env，并填写本地配置值。

# 用于 OpenAI 或兼容 OpenAI 接口的凭证。
OPENAI_API_KEY=

# 用于 PMC 智能体兼容旧配置的意图识别模型。
PMC_AGENT_INTENT_MODEL=gpt-5.4-mini

# 模型路由配置，不同动作可以使用不同模型。
PMC_AGENT_MODEL_DEFAULT=gpt-5.4-mini
PMC_AGENT_MODEL_INTENT_RECOGNITION=gpt-5.4-mini
PMC_AGENT_MODEL_GOAL_REPAIR=gpt-5.4
PMC_AGENT_MODEL_TOOL_ORCHESTRATION=gpt-5.4
PMC_AGENT_MODEL_FAILURE_HANDLING=gpt-5.4
PMC_AGENT_MODEL_BUSINESS_EXPLANATION=gpt-5.4
PMC_AGENT_MODEL_SUMMARY=gpt-5.4-mini
PMC_AGENT_MODEL_HIGH_RISK=gpt-5.4
PMC_AGENT_MODEL_LONG_CONTEXT_THRESHOLD=4000

# 接口基础地址。没有兼容网关或代理时使用 OpenAI 默认地址。
OPENAI_BASE_URL=https://api.openai.com/v1

# 可选请求超时时间，单位为秒。
PMC_AGENT_HTTP_TIMEOUT=30

# 日志级别：DEBUG、INFO、WARNING、ERROR 或 CRITICAL。
PMC_AGENT_LOG_LEVEL=INFO

# 每日记忆复盘调度的本地运行时间。
PMC_AGENT_MEMORY_REVIEW_TIME=18:00

# 将每日复盘生成的长期记忆持久化到独立的 Milvus 数据库和集合。
PMC_AGENT_MEMORY_MILVUS_ENABLED=false
PMC_AGENT_MEMORY_EMBEDDING_MODEL=text-embedding-3-large
PMC_AGENT_MEMORY_EMBEDDING_DIMENSIONS=1024
MILVUS_MEMORY_DATABASE=pmc_memory
MILVUS_MEMORY_COLLECTION_NAME=pmc_agent_memory
MILVUS_MEMORY_VECTOR_DIM=1024
MILVUS_MEMORY_AUTO_CREATE=true

# 可选的只读 STI 数据仓库连接器。
STI_DB_ENABLED=false
STI_DB_HOST=
STI_DB_PORT=9030
STI_DB_USER=
STI_DB_PASSWORD=
STI_DB_NAME=dw_leang
STI_DB_CHARSET=utf8mb4

# 可选的 Milvus 向量数据库连接器，用于 RAG 和知识检索。
MILVUS_HOST=
MILVUS_PORT=19530
MILVUS_URI=
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DATABASE=default
MILVUS_TIMEOUT=10
MILVUS_COLLECTION_NAME=leang_documents
VECTOR_DIM=1024
MILVUS_SECURE=False
MILVUS_ALIAS=default
MILVUS_VECTOR_FIELD=embedding
MILVUS_CONTENT_FIELD=text
MILVUS_SOURCE_FIELD=file_name

# 可选的 Neo4j 知识图谱连接器，用于表字段元数据、规则血缘和异常 Case 关系。
NEO4J_URI=bolt://10.0.10.106:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# 可选的飞书 WebSocket 机器人对接配置。
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_NAME=PMC库存智能体
FEISHU_API_BASE_URL=https://open.feishu.cn
FEISHU_EVENT_VERIFICATION_TOKEN=
FEISHU_MAX_WORKERS=4
FEISHU_MAX_MESSAGE_LENGTH=3500

# 可选的飞书审核和流程审批对接配置。
FEISHU_REVIEW_ENABLED=true
FEISHU_REVIEW_MODE=card_or_approval
FEISHU_DEFAULT_CHAT_ID=
FEISHU_PURCHASE_REVIEW_CHAT_ID=
FEISHU_SHIPMENT_REVIEW_CHAT_ID=
FEISHU_CASE_FOLLOWUP_CHAT_ID=
FEISHU_APPROVAL_ENABLED=false
FEISHU_APPROVAL_BUSINESS_TYPES=purchase_confirmation,shipment_confirmation,case_close
FEISHU_APPROVAL_RISK_LEVELS=critical,high
FEISHU_APPROVAL_PURCHASE_CODE=
FEISHU_APPROVAL_SHIPMENT_CODE=
FEISHU_APPROVAL_CASE_CLOSE_CODE=
FEISHU_APPROVAL_DEFAULT_CODE=
FEISHU_APPROVAL_START_OPEN_ID=
FEISHU_APPROVAL_START_USER_ID=
FEISHU_APPROVAL_FREE_NODE_ID=
FEISHU_APPROVAL_PURCHASE_NODE_ID=
FEISHU_APPROVAL_SHIPMENT_NODE_ID=
FEISHU_APPROVAL_CASE_CLOSE_NODE_ID=
