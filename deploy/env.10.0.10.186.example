# 10.0.10.186 部署示例。
# 复制到项目根目录 .env 后，再补齐密钥、数据库和飞书应用凭证。

PMC_WEB_PORT=80

FEISHU_LOGIN_ENABLED=true
PMC_AUTH_REQUIRED=true
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_API_BASE_URL=https://open.feishu.cn

# Docker 前端通过 /api 反代到后端，所以飞书 OAuth 回调也走 /api/auth/...
FEISHU_AUTH_REDIRECT_URI=http://10.0.10.186/api/auth/feishu/callback
FRONTEND_URL=http://10.0.10.186

# 生产请换成随机长字符串，例如 32 字节以上。
PMC_SESSION_SECRET=replace-with-a-long-random-secret
PMC_SESSION_COOKIE_NAME=pmc_session
PMC_SESSION_COOKIE_SECURE=false
PMC_SESSION_TTL_SECONDS=28800

PMC_PERMISSION_RULES_PATH=config/feishu_permissions.json
PMC_AUTH_ADMIN_OPEN_IDS=
PMC_AUTH_ADMIN_USER_IDS=
PMC_AUTH_DEFAULT_PERSON_SCOPE_FIELD=salesman

# 已有项目配置照常补齐。
PMC_AGENT_LOG_LEVEL=INFO
STI_DB_ENABLED=false
STI_DB_HOST=
STI_DB_PORT=9030
STI_DB_USER=
STI_DB_PASSWORD=
STI_DB_NAME=dw_leang
